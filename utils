#!/bin/sh

# Se l'argomento è un numero, cerca ed esegue la riga corrispondente
if [[ $1 =~ ^[0-9]+$ ]]; then
    # Estrae la riga N, rimuove il prefisso "# SCR: " e la esegue
    cmd=$(sed -n "${1}p" "$0" | sed 's/^# SCR: //')
    if [ -z "$cmd" ]; then
        echo "Errore: Nessun comando trovato alla posizione $1"
    else
        eval "$cmd"
    fi
    exit 0
fi

# Se l'argomento è un testo (non numero), lo aggiunge in coda come commento speciale
if [ "$#" -gt 0 ]; then
    echo "# SCR: $@" >> "$0"
    echo "Comando salvato in posizione: $(wc -l < "$0")"
    exit 0
fi

echo "Utilizzo:"
echo "  ./utils \"comando\"   -> Salva un nuovo script"
echo "  ./utils <numero>    -> Esegue lo script salvato a quella riga"
